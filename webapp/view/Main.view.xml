<mvc:View
	controllerName="activity.weekly.controller.Main"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:p="sap.m.plugins"
	xmlns="sap.m">
    <Page id="WeeklyActivityID">
        <Table id="WeeklyActivityTable"
            inset="false"
            items="{
                path: 'WeeklyActivity>/WeeklyActivity'
            }"
            growing="true"
            growingScrollToLoad="false"
            growingThreshold="10"
            width="100%">
            <headerToolbar>
                <OverflowToolbar>
                    <content/>
                </OverflowToolbar>
            </headerToolbar>
            <columns>
                <Column
                    hAlign="Center"
                    minScreenWidth="Tablet"
                    demandPopin="true">
                    <Text text="ID" />
                </Column>
                <Column
                    hAlign="Center"
                    minScreenWidth="Tablet"
                    demandPopin="true">
                    <Text text="Image" />
                </Column>
            </columns>
            <items>
                <ColumnListItem vAlign="Middle">
                    <cells>
                        <Text text="{WeeklyActivity>ID}"/>
                        <Image
                            src="{WeeklyActivity>DocumentLink}"
                            width="50px"
                            height="50px"
                            press="onImagePress"
                            tooltip="Click to view full image"
                        />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </Page>
</mvc:View>